# ── Vercel KV (Upstash Redis) ──────────────────────────────────────
# Create a KV / Upstash Redis store in the Vercel dashboard, then copy
# the REST credentials here (Vercel injects them automatically in prod).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Admin auth ─────────────────────────────────────────────────────
# Single shared admin password exchanged for a JWT at /api/auth/login.
ADMIN_PASSWORD=
# Secret used to sign admin JWTs. Use a long random string, e.g.
#   openssl rand -base64 32
JWT_SECRET=

# ── Storefront ─────────────────────────────────────────────────────
# WhatsApp number used for the WhatsApp checkout / contact (no "+").
VITE_WHATSAPP_NUMBER=905015317748
